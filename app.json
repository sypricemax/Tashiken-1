{
  "expo": {
    "name": "Karate Club",
    "slug": "tashiken-karate",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EF4444"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tashiken.karate",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "youtube"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#EF4444"
      },
      "package": "com.tashiken.karate",
      "versionCode": 7,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "*.youtube.com",
              "pathPrefix": "/watch"
            },
            {
              "scheme": "https",
              "host": "youtu.be"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
  "expo-router",
  [
    "expo-build-properties",
    {
      "android": {
        "compileSdkVersion": 35,
        "targetSdkVersion": 35,
        "buildToolsVersion": "35.0.0"
      }
    }
  ]
],
	
	
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "scheme": "tashiken",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2318acf8-06ca-49ff-8af2-b4845619cdee"
      }
    }
  }
}
